# Build stage
FROM golang:{{ .GoVersion }}-alpine AS builder

# Install ca-certificates for HTTPS requests and git for private repos if needed
RUN apk add --no-cache ca-certificates git

# Set working directory
WORKDIR /app

# Copy go mod and sum files
# Support both layouts: go.mod in code/ (standard) or at service root
COPY code/go.mod* code/go.sum* ./code/
COPY go.mod* go.sum* ./

# Download dependencies (try code/ first, fall back to root)
RUN if [ -f code/go.mod ]; then cd code && go mod download; elif [ -f go.mod ]; then go mod download; fi

# Copy the source code
{{ range .Components}}
COPY {{.}} {{.}}
{{end}}

# Build the binary
# Detect source location: code/ or root
RUN if [ -f code/go.mod ]; then \
      cd code && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags='-w -s -extldflags "-static"' -o /app/app; \
    else \
      CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags='-w -s -extldflags "-static"' -o /app/app ./cmd/server; \
    fi

# Final stage
FROM alpine:{{ .AlpineVersion }}

# Install ca-certificates for HTTPS requests
RUN apk add --no-cache ca-certificates

# Set working directory
WORKDIR /app

# Set environment variables
{{ range .Envs}}
ENV {{.Key}}={{.Value}}
{{end}}

# Create a non-root user
RUN adduser -D appuser

# Copy the binary from the builder stage
COPY --chown=appuser --from=builder /app/app .

# Use the non-root user
USER appuser

# Expose ports
EXPOSE 8080 9090

# Run the binary
CMD ["./app"]
