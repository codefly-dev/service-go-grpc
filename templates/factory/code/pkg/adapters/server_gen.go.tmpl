import (
	"{{ .Service.Name.DNSCase }}/plugins"
	"context"
	"fmt"
)

type Server struct {
	grpc    *GrpcServer
	{{- if .Settings.RestEndpoint }}
	rest    *RestServer
	{{- end }}
	connect *ConnectServer
}

func NewServer(config *Configuration) (*Server, error) {

	grpc, err := NewGrpServer(config)
	if err != nil {
		return nil, err
	}

	// Register plugins on the gRPC server
	for _, p := range plugins.All() {
		p.RegisterGRPC(grpc.gRPC)
	}

	{{- if .Settings.RestEndpoint }}
	var rest *RestServer
	if config.EndpointHttpPort != nil {
		rest, err = NewRestServer(config)
		if err != nil {
			return nil, err
		}
	}
	{{- end }}

	var conn *ConnectServer
	if config.EndpointConnectPort != nil {
		conn, err = NewConnectServer(config)
		if err != nil {
			return nil, err
		}
	}

	return &Server{
		grpc:    grpc,
		{{- if .Settings.RestEndpoint }}
		rest:    rest,
		{{- end }}
		connect: conn,
	}, nil
}

func (server *Server) Start(ctx context.Context) error {
	{{- if .Settings.RestEndpoint }}
	if server.rest != nil {
		go func() {
			err := server.rest.Run(ctx)
			if err != nil {
				panic(err)
			}
		}()
	}
	{{- end }}
	if server.connect != nil {
		go func() {
			err := server.connect.Run(ctx)
			if err != nil {
				panic(err)
			}
		}()
	}
	return server.grpc.Run(ctx)
}

func (server *Server) Stop() {
	fmt.Println("Stopping server...")
	server.grpc.health.Shutdown()
	server.grpc.gRPC.GracefulStop()
}
